# Render Environment Variables - جاهز للنسخ واللصق
# استبدل القيم بين < > بالقيم الفعلية من قاعدة البيانات

NODE_ENV=production
PORT=3000
DATABASE_URL=<paste_your_database_url_from_postgresql_connection_section>
JWT_SECRET=pig-super-secret-jwt-key-2024-secure-random-string-change-in-production
FRONTEND_URL=https://eilut.github.io/pig/
DB_NAME=pig
DB_USER=pig_user
DB_PASSWORD=<paste_db_password_from_database_url>
DB_HOST=<paste_db_host_from_database_url>
DB_PORT=5432

# مثال لـ DATABASE_URL كيف سيبدو:
# postgres://pig_user:AbCdEf123456@pig-db.compute-1.amazonaws.com:5432/pig
# في هذه الحالة:
# DB_PASSWORD = AbCdEf123456
# DB_HOST = pig-db.compute-1.amazonaws.com
